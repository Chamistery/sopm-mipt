# Скопируй в .env и заполни. docker-compose автоматически подхватит.
# В git коммитить .env нельзя, только этот .env.example.

# Внешний порт для nginx с SPA + API-прокси
PORT=8080

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sopm

# Общий секрет между project-service и distribution-service.
# В проде заменить на длинную случайную строку, например:
#   openssl rand -hex 32
# Если пустой, service-token auth выключен (distribution-service не сможет
# ходить к защищённым ручкам project-service'а).
INTERNAL_SERVICE_TOKEN=
