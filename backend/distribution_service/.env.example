# HTTP Server Configuration
DIST_SERVICE_http_port=8090

# Projects Service (project-service в одной docker-сети)
DIST_SERVICE_projects_service_url=http://project-service:8080
DIST_SERVICE_projects_endpoint=/api/projects

# Users Service (студенты)
DIST_SERVICE_users_service_url=http://project-service:8080
DIST_SERVICE_users_endpoint=/api/users

# Applications Service
DIST_SERVICE_applications_service_url=http://project-service:8080
DIST_SERVICE_applications_endpoint=/api/applications/project

# Service-token для прохода через middleware project-service
# (должен совпадать с INTERNAL_SERVICE_TOKEN на стороне Go)
DIST_SERVICE_internal_service_token=

# HTTP timeout (ms)
DIST_SERVICE_http_timeout_ms=30000

# Logging
DIST_SERVICE_log_level=INFO
DIST_SERVICE_log_file=./logs/distribution_service.log
