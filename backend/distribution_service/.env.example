# HTTP Server Configuration
DIST_SERVICE_HTTP_PORT=8080

# Projects Service
DIST_SERVICE_PROJECTS_SERVICE_URL=http://localhost:8080
DIST_SERVICE_PROJECTS_ENDPOINT=/api/projects
DIST_SERVICE_PROJECT_ENDPOINT=/api/projects/{id}

# Users Service (для студентов и их рейтингов)
DIST_SERVICE_USERS_SERVICE_URL=http://localhost:8080
DIST_SERVICE_USERS_ENDPOINT=/api/users

# Applications Service
DIST_SERVICE_APPLICATIONS_SERVICE_URL=http://localhost:8080
DIST_SERVICE_APPLICATIONS_ENDPOINT=/api/applications/project
DIST_SERVICE_APPLICATION_UPDATE_ENDPOINT=/api/applications/{id}/recommend

# HTTP Configuration
DIST_SERVICE_HTTP_TIMEOUT_MS=30000

# Logging
DIST_SERVICE_LOG_LEVEL=INFO
DIST_SERVICE_LOG_FILE=./logs/distribution_service.log
